generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PLATFORM_ADMIN
  TENANT_OWNER
  STAFF
  CUSTOMER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

model Tenant {
  id                     String             @id @default(cuid())
  slug                   String             @unique
  name                   String
  description            String?
  logoUrl                String?
  primaryColor           String             @default("#4F46E5")
  businessHours          Json
  timezone               String             @default("America/New_York")
  stripeConnectAccountId String?
  stripeCustomerId       String?
  subscriptionPlan       SubscriptionPlan   @default(STARTER)
  subscriptionStatus     SubscriptionStatus @default(TRIALING)
  status                 TenantStatus       @default(ACTIVE)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  users               User[]
  services            Service[]
  staffAvailabilities StaffAvailability[]
  clients             Client[]
  appointments        Appointment[]
  payments            Payment[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String?
  email        String   @unique
  passwordHash String
  role         Role
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant              Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffAvailabilities StaffAvailability[]
  appointmentsAsStaff Appointment[]       @relation("StaffAppointments")

  @@index([tenantId])
  @@map("users")
}

model Service {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  durationMinutes  Int
  price            Int
  assignedStaffIds String[]
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId])
  @@map("services")
}

model StaffAvailability {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  dayOfWeek  Int
  startTime  String
  endTime    String
  exceptions Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("staff_availabilities")
}

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("clients")
}

model Appointment {
  id             String            @id @default(cuid())
  tenantId       String
  serviceId      String
  staffId        String
  clientId       String
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(PENDING)
  paymentStatus  PaymentStatus     @default(PENDING)
  notes          String?
  reminderSentAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service  Service   @relation(fields: [serviceId], references: [id])
  staff    User      @relation("StaffAppointments", fields: [staffId], references: [id])
  client   Client    @relation(fields: [clientId], references: [id])
  payments Payment[]

  @@index([tenantId, staffId, startTime])
  @@index([startTime, reminderSentAt])
  @@map("appointments")
}

model Payment {
  id                    String        @id @default(cuid())
  tenantId              String
  appointmentId         String
  stripePaymentIntentId String?       @unique
  stripeSessionId       String?
  amount                Int
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@map("payments")
}

model StripeEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  type      String
  processed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("stripe_events")
}

enum AuditEventType {
  TENANT_CREATED
  TENANT_SUSPENDED
  TENANT_ACTIVATED
  TENANT_DELETED
  ADMIN_IMPERSONATED_TENANT
  IMPERSONATION_ENDED
  PLAN_CHANGED
  FEATURE_FLAG_TOGGLED
  APPOINTMENT_STATUS_CHANGED
  PAYMENT_PROCESSED
}

model AuditLog {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())
  actorId     String
  actorEmail  String
  eventType   AuditEventType
  description String
  tenantId    String?
  metadata    Json?

  @@map("audit_logs")
}

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String
  tenantId  String?
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String

  @@unique([key, tenantId])
  @@map("feature_flags")
}
